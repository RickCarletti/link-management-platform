generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model AuditLog {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  action    String   // CREATE | UPDATE | DELETE
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())
}

model Link {
  id        String   @id @default(uuid())
  original  String
  shortCode String   @unique
  createdAt DateTime @default(now())
}