generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  action    String   // CREATE | UPDATE | DELETE
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id        String   @id @default(uuid())
  original  String
  shortCode String   @unique
  createdAt DateTime @default(now())
}